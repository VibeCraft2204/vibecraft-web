---
import { clients } from '../data/clients';

const repeated = [...clients, ...clients, ...clients, ...clients];
---

<section class="marquee-section">
  <div class="marquee-inner">
    <p class="marquee-label">Trusted by</p>
    <div class="marquee-wrapper">
      <div class="marquee-track">
        {repeated.map((client) => (
          <span class="marquee-item">
            <img src={client.logo} alt={client.name} class="client-logo" loading="lazy" />
          </span>
        ))}
        {repeated.map((client) => (
          <span class="marquee-item" aria-hidden="true">
            <img src={client.logo} alt="" class="client-logo" loading="lazy" />
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-section {
    background: var(--dark-bg);
    border-bottom: 1px solid var(--dark-border);
    padding: 48px 0;
  }

  .marquee-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .marquee-label {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dark-text-secondary);
    margin-bottom: 32px;
    font-weight: 400;
  }

  .marquee-wrapper {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .marquee-track {
    display: flex;
    gap: 0;
    width: max-content;
    animation: marquee-scroll 40s linear infinite;
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 0 48px;
    white-space: nowrap;
  }

  .client-logo {
    height: 28px;
    width: auto;
    filter: invert(1) brightness(2);
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .marquee-item:hover .client-logo {
    opacity: 0.9;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  @media (max-width: 640px) {
    .marquee-section {
      padding: 36px 0;
    }

    .marquee-label {
      margin-bottom: 24px;
    }

    .marquee-item {
      padding: 0 32px;
    }

    .client-logo {
      height: 22px;
    }

    .item-name {
      font-size: 13px;
    }
  }
</style>
